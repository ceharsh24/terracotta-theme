{
  "name": "terracotta-theme",
  "displayName": "Terracotta Theme",
  "description": "Warm, WCAG-compliant theme with 5 variants including a color-blind mode",
  "version": "1.4.0",
  "publisher": "terracotta-theme",
  "license": "MIT",
  "author": "Harsh Choudhary (https://github.com/ceharsh24)",
  "homepage": "https://github.com/ceharsh24/terracotta-theme",
  "bugs": {
    "url": "https://github.com/ceharsh24/terracotta-theme/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "light",
    "color-blind",
    "accessible",
    "warm",
    "terracotta",
    "wcag"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ceharsh24/terracotta-theme"
  },
  "qna": false,
  "extensionKind": [
    "ui"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#141414",
    "theme": "dark"
  },
  "scripts": {
    "test": "node scripts/check-contrast.js"
  },
  "contributes": {
    "themes": [
      {
        "label": "Terracotta Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/terracotta-dark.json"
      },
      {
        "label": "Terracotta Dark Dimmed",
        "uiTheme": "vs-dark",
        "path": "./themes/terracotta-dark-dimmed.json"
      },
      {
        "label": "Terracotta Light",
        "uiTheme": "vs",
        "path": "./themes/terracotta-light.json"
      },
      {
        "label": "Terracotta Light Bright",
        "uiTheme": "vs",
        "path": "./themes/terracotta-light-bright.json"
      },
      {
        "label": "Terracotta High Contrast (Color Blind)",
        "uiTheme": "hc-dark",
        "path": "./themes/terracotta-high-contrast-cb.json"
      }
    ]
  }
}
