  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4A525A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#586068",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#996300"
      }
    },
    {
      "name": "String escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#996300"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#AB2B85"
      }
    },
    {
      "name": "Template string expressions",
      "scope": [
        "string.template punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#996300"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C21562"
      }
    },
    {
      "name": "Built-in constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#C21562",
        "fontStyle": "italic"
      }
    },
    {
      "name": "User constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#C21562"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#B84221"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#B84221"
      }
    },
    {
      "name": "Keyword operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#005EB8"
      }
    },
    {
      "name": "Keyword operator logical",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#005EB8"
      }
    },
    {
      "name": "Keyword operator assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#005EB8"
      }
    },
    {
      "name": "Keyword new/delete",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#B84221"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#B84221"
      }
    },
    {
      "name": "Storage modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B84221"
      }
    },
    {
      "name": "Function declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#007A5E"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#007A5E"
      }
    },
    {
      "name": "Method call",
      "scope": [
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#007A5E"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#116329"
      }
    },
    {
      "name": "Class name",
      "scope": [
        "entity.name.type.class",
        "entity.name.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6B33C2"
      }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0550AE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interface",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#6B33C2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Enum",
      "scope": [
        "entity.name.type.enum"
      ],
