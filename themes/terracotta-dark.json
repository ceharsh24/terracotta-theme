  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A8578",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#868276",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#F0C24E"
      }
    },
    {
      "name": "String escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#E8A050"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#E1ABC1"
      }
    },
    {
      "name": "Template string expressions",
      "scope": [
        "string.template punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#F0C24E"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D890A0"
      }
    },
    {
      "name": "Built-in constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#D4A090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "User constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#CC8858"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#E98665"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#E98665"
      }
    },
    {
      "name": "Keyword operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7FC7F4"
      }
    },
    {
      "name": "Keyword operator logical",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#7FC7F4"
      }
    },
    {
      "name": "Keyword operator assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#7FC7F4"
      }
    },
    {
      "name": "Keyword new/delete",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#E98665"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#E98665"
      }
    },
    {
      "name": "Storage modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E98665"
      }
    },
    {
      "name": "Function declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#3DBB92"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#3DBB92"
      }
    },
    {
      "name": "Method call",
      "scope": [
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#3DBB92"
      }
    },
    {
