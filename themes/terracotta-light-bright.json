  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#525962",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#4F5862",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#7C4F00"
      }
    },
    {
      "name": "String escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#7C4F00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#9B2080"
      }
    },
    {
      "name": "Template string expressions",
      "scope": [
        "string.template punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#7C4F00"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#AA0E53"
      }
    },
    {
      "name": "Built-in constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#AA0E53",
        "fontStyle": "italic"
      }
    },
    {
      "name": "User constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#AA0E53"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#9E341A"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#9E341A"
      }
    },
    {
      "name": "Keyword operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0055A8"
      }
    },
    {
      "name": "Keyword operator logical",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#0055A8"
      }
    },
    {
      "name": "Keyword operator assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#0055A8"
      }
    },
    {
      "name": "Keyword new/delete",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#9E341A"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9E341A"
      }
    },
    {
      "name": "Storage modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9E341A"
      }
    },
    {
      "name": "Function declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#00654D"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#00654D"
      }
    },
    {
      "name": "Method call",
      "scope": [
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#00654D"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#0E5A2A"
      }
    },
    {
      "name": "Class name",
      "scope": [
        "entity.name.type.class",
        "entity.name.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5E29AD"
      }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0349A4",
