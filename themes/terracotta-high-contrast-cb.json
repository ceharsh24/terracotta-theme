  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A0A0A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#9898A8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#FFDF33"
      }
    },
    {
      "name": "String escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FFDF33",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#E1D4F2"
      }
    },
    {
      "name": "Template string expressions",
      "scope": [
        "string.template punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#FFDF33"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFB000"
      }
    },
    {
      "name": "Built-in constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#FF66C4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "User constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#FFB000"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#FF8A5C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#FF8A5C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#80BFFF"
      }
    },
    {
      "name": "Keyword operator logical",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#80BFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operator assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#80BFFF"
      }
    },
    {
      "name": "Keyword new/delete",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#FF8A5C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#FF8A5C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF8A5C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function declaration",
